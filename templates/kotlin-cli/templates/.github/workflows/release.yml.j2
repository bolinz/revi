name: Release

on:
  push:
    branches: [main]
    tags: ['v*']

jobs:
  release:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v5
      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 11
          cache: gradle
      - name: Build
        run: ./gradlew build --release
      - name: Create GitHub Release
        uses: softprops/action-gh-release@v1
        with:
          files: build/libs/*.jar
          body: |
            Release for ${{ github.ref_name }}

            Binary artifacts are published to GitHub Releases.
            Add platform-specific native image configuration in release notes.
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
